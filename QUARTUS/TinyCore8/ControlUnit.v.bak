`include "Definitions.v"

module ControlUnit (
    input wire clk,
    input wire reset,

    input wire [11:0] instruction,
    input wire [7:0] aluResult,

    // --- Sinais de Controle para o Datapath ---
    output reg pcLoadEnable,
    output reg pcIncEnable,
    output reg regWriteEnableA,
    output reg regWriteEnableB,
    output reg regAInMSuxSel,  // 0: RAM, 1: Imediato
    output reg regBInMuxSel,  // 0: RAM, 1: Imediato
    output reg aluIn2MuxSel,  // 0: Reg B, 1: Zero
    output reg [1:0] ramInMuxSel, // 00: ALU, 01: Reg A, 10: Reg B
    
    // CORRECAO: Voltamos para 5 bits, como a ALU original espera
    output reg [4:0] aluSelector, 

    // --- Sinal de Controle para a RAM de Dados ---
    output reg ramWriteEnable
);

    // --- Fios Internos ---
    wire [3:0] opcode;
    assign opcode = instruction[11:8];

    // Registradores de estado
    reg [3:0] state, nextState;

    // Variavel temporaria para a logica de traducao da ALU
    reg [4:0] aluSelectorSignal;

    // --- Logica Sequencial (Registradores de Estado) ---
    always @(posedge clk) begin
        if (reset) begin
            state <= `RESET;
        end else begin
            state <= nextState;
        end
    end

    // --- Logica Combinacional (Saidas e Proximo Estado) ---
    always @(*) begin
        // Valores padrao (seguros)
        pcLoadEnable    = 1'b0;
        pcIncEnable     = 1'b0;
        regWriteEnableA = 1'b0;
        regWriteEnableB = 1'b0;
        regAInMuxSel    = 1'b0;
        regBInMuxSel    = 1'b0;
        aluIn2MuxSel    = 1'b0;
        ramInMuxSel     = 2'b00;
        ramWriteEnable  = 1'b0;
        
        // Padrao do seletor da ALU (NOP / Invalido)
        aluSelectorSignal = 5'b11111; 
        nextState         = `FETCH;

        // --- CORRECAO: Logica de traducao (4-bit opcode -> 5-bit ALU) ---
        // Aqui traduzimos os opcodes da instrucao para os opcodes que a ALU entende
        // Os valores de 5 bits sao da ALU.v original [cite: 90, 93-107]
        case (opcode)
            `ADD: aluSelectorSignal = 5'b00100; // OP_ADD
            `SUB: aluSelectorSignal = 5'b00101; // OP_SUB
            `MUL: aluSelectorSignal = 5'b00110; // OP_MUL
            `DIV: aluSelectorSignal = 5'b00111; // OP_DIV
            `AND: aluSelectorSignal = 5'b01000; // OP_AND
            `OR:  aluSelectorSignal = 5'b01010; // OP_OR
            `XOR: aluSelectorSignal = 5'b01011; // OP_XOR
            `CMP: aluSelectorSignal = 5'b01100; // OP_CMP
            `NOT: aluSelectorSignal = 5'b01101; // OP_NOT
            // O JMP usa o `OP_CMP` internamente
            `JMP: aluSelectorSignal = 5'b01100; // OP_CMP
        endcase

        // Logica de decisao baseada no estado atual
        case (state)
            `RESET: begin
                nextState = `FETCH;
            end

            `FETCH: begin
                pcIncEnable = 1'b1;
                nextState = `DECODE;
            end

            `DECODE: begin
                case (opcode)
                    `LDC: nextState = `EXEC_LDC;
                    `STA: nextState = `EXEC_STA;
                    `STB: nextState = `EXEC_STB;
                    `LDA: nextState = `EXEC_LDA;
                    `LDB: nextState = `EXEC_LDB;
                    `JMP: nextState = `EXEC_JMP;
                    
                    // Todas as operacoes ALU vao para o mesmo estado
                    `ADD, `SUB, `AND, `OR, `XOR, `MUL, `DIV, `NOT, `CMP: begin
                        nextState = `EXEC_ALU;
                    end
                    
                    default: nextState = `FETCH;
                endcase
            end

            `EXEC_LDC: begin
                regAInMuxSel    = 1'b1;
                regWriteEnableA = 1'b1;
                nextState       = `FETCH;
            end

            `EXEC_STA: begin
                ramInMuxSel    = 2'b01;
                ramWriteEnable = 1'b1;
                nextState      = `FETCH;
            end
            
            `EXEC_STB: begin
                ramInMuxSel    = 2'b10;
                ramWriteEnable = 1'b1;
                nextState      = `FETCH;
            end

            `EXEC_LDA: begin
                regAInMuxSel = 1'b0;
                nextState    = `WRITE_REGA;
            end
            `WRITE_REGA: begin
                regWriteEnableA = 1'b1;
                nextState       = `FETCH;
            end

            `EXEC_LDB: begin
                regBInMuxSel = 1'b0;
                nextState    = `WRITE_REGB;
            end
            `WRITE_REGB: begin
                regWriteEnableB = 1'b1;
                nextState       = `FETCH;
            end

            // Estado para todas as operacoes ALU (ADD, SUB, AND, etc.)
            `EXEC_ALU: begin
                aluIn2MuxSel = 1'b0;    // Seleciona Reg B
                // A traducao do seletor ja foi feita acima
                nextState    = `WRITE_RAM;
            end
            `WRITE_RAM: begin
                ramInMuxSel    = 2'b00; // Seleciona resultado da ALU
                ramWriteEnable = 1'b1;  // Escreve na RAM
                nextState      = `FETCH;
            end

            `EXEC_JMP: begin
                aluIn2MuxSel = 1'b1;    // Seleciona Zero
                // A traducao ja foi feita (JMP -> OP_CMP)
                nextState    = `EXEC_JMP_2;
            end
            `EXEC_JMP_2: begin
                if (aluResult == 8'h00) begin // A == 0 ?
                    pcLoadEnable = 1'b1;
                end
                // Se nao for igual, nao faz nada (o PC ja incrementou em FETCH)
                // CORRECAO: Otimizado. O PC nao deve incrementar em FETCH se
                // a proxima instrucao for JMP. Ajuste necessario.

                // --- AJUSTE DE LOGICA IMPORTANTE ---
                // O PC nao pode incrementar no FETCH se a instrucao for um JMP
                // Vamos refatorar isso.
                nextState = `FETCH;
            end

            default: begin
                nextState = `RESET;
            end
        endcase

        // Atribui o sinal da ALU no final
        aluSelector = aluSelectorSignal;
    end

endmodule