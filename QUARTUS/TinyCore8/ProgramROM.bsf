(header "symbol" (version "1.2"))
(symbol
	(rect 64 64 272 312)
	(text "ProgramROM" (rect 56 104 149 120)(font "Arial" (color 225 194 79)(font_size 10)))
	(text "inst" (rect 96 88 113 100)(font "Arial" (color 225 194 79)))
	(port
		(pt 208 56)
		(input)
		(text "address[7..0]" (rect 0 40 75 54)(font "Arial" (font_size 8)))
		(text "address[7..0]" (rect 108 48 183 62)(font "Arial" (color 225 194 79)(font_size 8)))
		(line (pt 192 56)(pt 208 56)(color 225 194 79)(line_width 3))
	)
	(port
		(pt 40 248)
		(input)
		(text "clock" (rect 0 120 29 134)(font "Arial" (font_size 8)))
		(text "clock" (rect 32 200 46 229)(font "Arial" (color 225 194 79)(font_size 8))(vertical))
		(line (pt 40 248)(pt 40 232)(color 225 194 79))
	)
	(port
		(pt 208 40)
		(output)
		(text "q[11..0]" (rect -8 40 34 54)(font "Arial" (font_size 8)))
		(text "q[11..0]" (rect 144 32 186 46)(font "Arial" (color 225 194 79)(font_size 8)))
		(line (pt 208 40)(pt 192 40)(color 225 194 79)(line_width 3))
	)
