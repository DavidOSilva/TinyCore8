		(text "12 bits" (rect 85 122 118 134)(font "Arial" (color 225 194 79)))
		(line (pt 0 40)(pt 0 40)(color 251 236 93))
		(line (pt 0 40)(pt 0 40)(color 251 236 93))
		(rectangle (rect 16 16 192 232)(color 225 194 79))
	)
	(fill (color 251 244 202))
)
